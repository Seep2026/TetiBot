{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Teti",
  "version": "0.1.0",
  "identifier": "ai.seep.teti.chatmail",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "mail",
        "title": "Teti Mail",
        "url": "index.html?mode=mail",
        "width": 980,
        "height": 700,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' asset: data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "SocialNetworking",
    "shortDescription": "A Delta Chat compatible pet client"
  }
}
